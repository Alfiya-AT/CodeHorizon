// schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite" // Adapted for local dev, switch back to "mysql" for production
  url      = "file:./dev.db"
}

model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  passwordHash  String
  name          String
  avatarUrl     String?
  role          String    @default("STUDENT") // SQLite doesn't support Enums directly
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  enrollments     Enrollment[]
  videoProgress   VideoProgress[]
  refreshTokens   RefreshToken[]
  subscriptions   Subscription[]
}

model Subject {
  id            Int       @id @default(autoincrement())
  title         String
  slug          String    @unique
  description   String    
  thumbnailUrl  String?
  trailerUrl    String?   
  price         Decimal   @default(0) 
  currency      String    @default("INR")
  isPublished   Boolean   @default(false)
  isFeatured    Boolean   @default(false)
  level         String    @default("BEGINNER")
  language      String    @default("English")
  tags          String?   
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sections      Section[]
  enrollments   Enrollment[]
  subscriptions Subscription[]
}

model Section {
  id          Int      @id @default(autoincrement())
  subjectId   Int
  title       String
  orderIndex  Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  videos      Video[]

  @@unique([subjectId, orderIndex])
  @@index([subjectId])
}

model Video {
  id              Int      @id @default(autoincrement())
  sectionId       Int
  title           String
  description     String?  
  youtubeVideoId  String   
  orderIndex      Int
  durationSeconds Int?
  isFreePreview   Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  section         Section        @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  progress        VideoProgress[]

  @@unique([sectionId, orderIndex])
  @@index([sectionId])
}

model Enrollment {
  id         Int      @id @default(autoincrement())
  userId     Int
  subjectId  Int
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])
  subject    Subject  @relation(fields: [subjectId], references: [id])

  @@unique([userId, subjectId])
}

model Subscription {
  id              Int               @id @default(autoincrement())
  userId          Int
  subjectId       Int
  status          String            @default("PENDING")
  paymentProvider String            
  paymentId       String?           
  amount          Decimal           
  currency        String
  expiresAt       DateTime?         
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  user            User              @relation(fields: [userId], references: [id])
  subject         Subject           @relation(fields: [subjectId], references: [id])
}


model VideoProgress {
  id                   Int      @id @default(autoincrement())
  userId               Int
  videoId              Int
  lastPositionSeconds  Int      @default(0)
  isCompleted          Boolean  @default(false)
  completedAt          DateTime?
  watchTimeSeconds     Int      @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user                 User     @relation(fields: [userId], references: [id])
  video                Video    @relation(fields: [videoId], references: [id])

  @@unique([userId, videoId])
}

model RefreshToken {
  id         Int      @id @default(autoincrement())
  userId     Int
  tokenHash  String
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])

  @@index([userId, tokenHash])
}
